# ============================================================
# PetroFlow ERP — Environment Variables Template
# ============================================================
# انسخ هذا الملف وسمّه .env ثم املأ القيم الحقيقية
# Copy this file to .env and fill in the real values
# ============================================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (MongoDB)
MONGO_URI=mongodb://localhost:27017/petroflow_erp

# Security & Authentication
# ⚠️ يجب أن يكون نصاً عشوائياً طويلاً (32+ حرف) ولا يُشارك مع أحد
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_STRING

# Email / SMTP Configuration
# للحصول على App Password: https://myaccount.google.com/apppasswords
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_gmail_app_password_here
MAIL_FROM=PetroFlow ERP <noreply@petroflow.com>

# Application URLs
FRONTEND_URL=http://localhost:3001
ALLOWED_ORIGIN=http://localhost:3001

# Seeder — Super Admin Default Credentials
# ⚠️ غيّر هذه القيم فور النشر على Production
ADMIN_EMAIL=admin@petroflow.com
ADMIN_DEFAULT_PASSWORD=Admin@123456

# File Uploads (Cloudinary) — اختياري
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
